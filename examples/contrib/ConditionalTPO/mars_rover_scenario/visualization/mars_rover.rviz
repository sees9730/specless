Panels:
  - Class: rviz_common/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Terrain1
        - /Path1
        - /Events1
        - /Rover1
      Splitter Ratio: 0.5
    Tree Height: 332
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Terrain
      Namespaces:
        ground: true
        mountains: true
        outcrop_rocks: true
        rocks: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /mars_rover/terrain
      Value: true
    - Alpha: 1
      Buffer Length: 1
      Class: rviz_default_plugins/Path
      Color: 255; 200; 0
      Enabled: true
      Head Diameter: 0.20000000298023224
      Head Length: 0.10000000149011612
      Length: 0.20000000298023224
      Line Style: Lines
      Line Width: 0.05000000074505806
      Name: Path
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Color: 255; 200; 0
      Pose Style: None
      Radius: 0.05000000074505806
      Shaft Diameter: 0.05000000074505806
      Shaft Length: 0.05000000074505806
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /mars_rover/path
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Events
      Namespaces:
        site_cone: true
        site_disc: true
        site_flag: true
        site_label: true
        site_legs: true
        site_light: true
        site_pad: true
        site_pole: true
        site_ring: true
        site_tile: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /mars_rover/events
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Effects
      Namespaces:
        drill_bit: true
        drill_dust: true
        gas_cloud: true
        smoke_e2: true
        smoke_e3: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /mars_rover/effects
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Rover
      Namespaces:
        rover_blanket: true
        rover_body: true
        rover_head: true
        rover_hubs: true
        rover_lens: true
        rover_mast: true
        rover_panel: true
        rover_rocker: true
        rover_rtg: true
        rover_wheels: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /mars_rover/rover
      Value: true
  Enabled: true
  Global Options:
    Background Color: 178; 140; 100
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 30.0
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point:
        X: 8.0
        Y: 3.5
        Z: 0.4
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 0.75
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz_default_plugins)
      Yaw: 1.05
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 900
  Hide Left Dock: false
  Hide Right Dock: true
  QMainWindow State: 
  Views:
    collapsed: false
  Width: 1400
  X: 0
  Y: 31
