Panels:
  - Class: rviz_common/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Environment1
        - /Path1
        - /Events1
        - /Robot1
      Splitter Ratio: 0.5
    Tree Height: 332
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Environment
      Namespaces:
        floor: true
        walls: true
        puddle: true
        decor_desk: true
        decor_chair: true
        decor_plant: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /office/environment
      Value: true
    - Alpha: 1
      Buffer Length: 1
      Class: rviz_default_plugins/Path
      Color: 0; 180; 255
      Enabled: true
      Head Diameter: 0.20000000298023224
      Head Length: 0.10000000149011612
      Length: 0.20000000298023224
      Line Style: Lines
      Line Width: 0.05000000074505806
      Name: Path
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Color: 0; 180; 255
      Pose Style: None
      Radius: 0.05000000074505806
      Shaft Diameter: 0.05000000074505806
      Shaft Length: 0.05000000074505806
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /office/path
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Events
      Namespaces:
        site_cone: true
        site_disc: true
        site_flag: true
        site_label: true
        site_legs: true
        site_light: true
        site_pad: true
        site_pole: true
        site_ring: true
        site_tile: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /office/events
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Effects
      Namespaces:
        puddle_ripple: true
        charge_spark: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /office/effects
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Robot
      Namespaces:
        robot_body: true
        robot_head: true
        robot_wheel_l: true
        robot_wheel_r: true
        robot_sensor: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /office/robot
      Value: true
  Enabled: true
  Global Options:
    Background Color: 220; 220; 220
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 11.3
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point:
        X: 6.0
        Y: 4.453
        Z: -0.38915
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 0.8
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz_default_plugins)
      Yaw: 1.57
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 900
  Hide Left Dock: false
  Hide Right Dock: true
  QMainWindow State: 
  Views:
    collapsed: false
  Width: 1400
  X: 0
  Y: 31
